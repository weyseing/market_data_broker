# market-data-broker — environment variable overrides.
#
# This file is documentation, not a runtime input. The hub reads its defaults
# from config/default.yaml and works without any env vars set. Variables here
# OVERRIDE the YAML at startup; nothing here is required.
#
# Quick examples:
#   MDB_WS_PORT=9000 ./scripts/start.sh                    # one-shot
#   set -a; source .env; set +a; ./scripts/start.sh        # persistent

# ---- Logging ---------------------------------------------------------------
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ---- Downstream WebSocket server ------------------------------------------
MDB_WS_HOST=0.0.0.0
MDB_WS_PORT=8765

# ---- Status HTTP endpoint (added in Step 10b) -----------------------------
MDB_STATUS_HOST=0.0.0.0
MDB_STATUS_PORT=8080

# ---- Coinbase upstream WebSocket ------------------------------------------
MDB_COINBASE_WS_URL=wss://ws-feed.exchange.coinbase.com
MDB_COINBASE_HEARTBEAT_TIMEOUT_SECONDS=15
MDB_COINBASE_INITIAL_BACKOFF_SECONDS=1
MDB_COINBASE_MAX_BACKOFF_SECONDS=30

# ---- Pub/sub bus -----------------------------------------------------------
MDB_BUS_CONSUMER_QUEUE_SIZE=1000
MDB_BUS_SUSTAINED_OVERFLOW_DROPS=100

# ---- Dev convenience -------------------------------------------------------
# Subscribe an in-process logging consumer to these topics on startup.
# Comma-separated. Useful for verifying ingest without a WS client.
# MDB_DEBUG_SUBSCRIBE=coinbase.ticker.BTC-USD,coinbase.matches.ETH-USD
